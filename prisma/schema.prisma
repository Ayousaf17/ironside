generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ApiLog {
  id             String   @id @default(uuid())
  endpoint       String
  method         String
  status         Int
  request        Json?
  response       Json?
  error          String?
  duration       Int?
  actorUser      String?  @map("actor_user")
  slackChannel   String?  @map("slack_channel")
  slackThreadTs  String?  @map("slack_thread_ts")
  ticketId       Int?     @map("ticket_id")
  intent         String?
  toolsUsed      String[] @map("tools_used")
  sessionId      String?  @map("session_id")
  tokenCount     Int?     @map("token_count")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("api_logs")
}

model PerformanceMetric {
  id        String   @id @default(uuid())
  metric    String
  value     Float
  unit      String?
  context   Json?
  source    String?
  sessionId String?  @map("session_id")
  endpoint  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("performance_metrics")
}

model PulseCheck {
  id               String   @id @default(uuid())
  channel          String?
  summary          String
  ticketCount      Int?     @map("ticket_count")
  insights         Json?
  rawAnalytics     Json?    @map("raw_analytics")
  status           String   @default("completed")
  openTickets      Int?     @map("open_tickets")
  closedTickets    Int?     @map("closed_tickets")
  spamRate         Float?   @map("spam_rate")
  avgResolutionMin Float?   @map("avg_resolution_min")
  topCategory      String?  @map("top_category")
  actionItems      Json?    @map("action_items")
  sessionId        String?  @map("session_id")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("pulse_checks")
}

model AgentBehaviorLog {
  id                   String   @id @default(uuid())
  gorgiasEventId       String?  @unique @map("gorgias_event_id")
  agent                String
  action               String   // reply, internal_note, assign, close, reopen, tag, macro_used, ticket_created
  ticketId             Int      @map("ticket_id")
  ticketSubject        String?  @map("ticket_subject")
  category             String?  // track_order, order_verification, product_question, report_issue, etc.
  responseText         String?  @map("response_text")
  macroIdUsed          Int?     @map("macro_id_used")
  macroName            String?  @map("macro_name")
  timeToRespondMin     Float?   @map("time_to_respond_min")
  touchesToResolution  Int?     @map("touches_to_resolution")
  reopened             Boolean  @default(false)
  csatScore            Int?     @map("csat_score")
  tagsApplied          String[] @map("tags_applied")
  rawEvent             Json?    @map("raw_event")
  occurredAt           DateTime @map("occurred_at")
  createdAt            DateTime @default(now()) @map("created_at")

  agentEmail        String?  @map("agent_email")
  ticketChannel     String?  @map("ticket_channel")
  ticketTags        String[] @map("ticket_tags")
  responseCharCount Int?     @map("response_char_count")
  messagePosition   Int?     @map("message_position")
  isFirstResponse   Boolean? @map("is_first_response")

  @@index([agent])
  @@index([ticketId])
  @@index([action])
  @@index([occurredAt])
  @@map("agent_behavior_logs")
}

// --- Session Tracking Chain (Phase 1) ---

model AgentSession {
  id             String         @id @default(uuid())
  slackChannel   String?        @map("slack_channel")
  slackThreadTs  String?        @map("slack_thread_ts")
  slackUserId    String?        @map("slack_user_id")
  userMessage    String         @map("user_message")
  status         String         @default("in_progress") // in_progress, completed, error
  durationMs     Int?           @map("duration_ms")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  requests       AgentRequest[]
  outcome        AgentOutcome?

  @@index([slackChannel])
  @@index([slackUserId])
  @@index([createdAt])
  @@map("agent_sessions")
}

model AgentRequest {
  id          String          @id @default(uuid())
  sessionId   String          @map("session_id")
  model       String
  promptKey   String?         @map("prompt_key")
  temperature Float?
  maxTokens   Int?            @map("max_tokens")
  createdAt   DateTime        @default(now()) @map("created_at")

  session     AgentSession    @relation(fields: [sessionId], references: [id])
  toolCalls   AgentToolCall[]

  @@index([sessionId])
  @@map("agent_requests")
}

model AgentToolCall {
  id         String       @id @default(uuid())
  requestId  String       @map("request_id")
  toolName   String       @map("tool_name")
  toolInput  Json?        @map("tool_input")
  toolOutput Json?        @map("tool_output")
  durationMs Int?         @map("duration_ms")
  success    Boolean      @default(true)
  error      String?
  createdAt  DateTime     @default(now()) @map("created_at")

  request    AgentRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@index([toolName])
  @@map("agent_tool_calls")
}

model AgentOutcome {
  id        String       @id @default(uuid())
  sessionId String       @unique @map("session_id")
  success   Boolean      @default(true)
  answer    String?
  error     String?
  toolsUsed String[]     @map("tools_used")
  createdAt DateTime     @default(now()) @map("created_at")

  session   AgentSession @relation(fields: [sessionId], references: [id])

  @@map("agent_outcomes")
}

// --- Token Tracking + Cost Visibility (Phase 2) ---

model AiTokenUsage {
  id               String   @id @default(uuid())
  sessionId        String?  @map("session_id")
  requestId        String?  @map("request_id")
  model            String
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  totalTokens      Int      @map("total_tokens")
  costUsd          Float    @map("cost_usd")
  source           String   // slack, cron
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@index([source])
  @@map("ai_token_usage")
}

// --- Schema Enrichment (Phase 3) — New Tables ---

model GorgiasUser {
  id          String   @id @default(uuid())
  gorgiasId   Int      @unique @map("gorgias_id")
  email       String   @unique
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  role        String?
  slackUserId String?  @map("slack_user_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("gorgias_users")
}

model DashboardConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("dashboard_config")
}

model ConversationContext {
  id                  String   @id @default(uuid())
  slackThreadTs       String   @unique @map("slack_thread_ts")
  slackChannel        String?  @map("slack_channel")
  slackUserId         String?  @map("slack_user_id")
  lastAction          String?  @map("last_action")
  lastTicketIds       Int[]    @map("last_ticket_ids")
  pendingConfirmation Json?    @map("pending_confirmation")
  messageCount        Int      @default(0) @map("message_count")
  expiresAt           DateTime @map("expires_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("conversation_contexts")
}

// --- Ticket Analytics + Confidence Scoring (Phase 5) ---

model TicketAnalytics {
  id                  String   @id @default(uuid())
  ticketId            Int      @unique @map("ticket_id")
  category            String?
  aiConfidenceScore   Float?   @map("ai_confidence_score")
  aiClassification    String?  @map("ai_classification")
  humanClassification String?  @map("human_classification")
  aiMatchesHuman      Boolean? @map("ai_matches_human")
  aiMessageCount      Int?     @map("ai_message_count")
  humanMessageCount   Int?     @map("human_message_count")
  resolutionTimeMin   Float?   @map("resolution_time_min")
  costSavingsUsd      Float?   @map("cost_savings_usd")
  touchCount          Int?     @map("touch_count")
  wasReopened         Boolean  @default(false) @map("was_reopened")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([aiConfidenceScore])
  @@index([aiMatchesHuman])
  @@map("ticket_analytics")
}
