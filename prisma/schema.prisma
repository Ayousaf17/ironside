generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ApiLog {
  id        String   @id @default(uuid())
  endpoint  String
  method    String
  status    Int
  request   Json?
  response  Json?
  error     String?
  duration  Int?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("api_logs")
}

model PerformanceMetric {
  id        String   @id @default(uuid())
  metric    String
  value     Float
  unit      String?
  context   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("performance_metrics")
}

model PulseCheck {
  id            String   @id @default(uuid())
  channel       String?
  summary       String
  ticketCount   Int?     @map("ticket_count")
  insights      Json?
  rawAnalytics  Json?    @map("raw_analytics")
  status        String   @default("completed")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("pulse_checks")
}

model AgentBehaviorLog {
  id                   String   @id @default(uuid())
  gorgiasEventId       String?  @unique @map("gorgias_event_id")
  agent                String
  action               String   // reply, internal_note, assign, close, reopen, tag, macro_used, ticket_created
  ticketId             Int      @map("ticket_id")
  ticketSubject        String?  @map("ticket_subject")
  category             String?  // track_order, order_verification, product_question, report_issue, etc.
  responseText         String?  @map("response_text")
  macroIdUsed          Int?     @map("macro_id_used")
  timeToRespondMin     Float?   @map("time_to_respond_min")
  touchesToResolution  Int?     @map("touches_to_resolution")
  reopened             Boolean  @default(false)
  csatScore            Int?     @map("csat_score")
  tagsApplied          String[] @map("tags_applied")
  rawEvent             Json?    @map("raw_event")
  occurredAt           DateTime @map("occurred_at")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([agent])
  @@index([ticketId])
  @@index([action])
  @@index([occurredAt])
  @@map("agent_behavior_logs")
}

// --- Session Tracking Chain (Phase 1) ---

model AgentSession {
  id             String         @id @default(uuid())
  slackChannel   String?        @map("slack_channel")
  slackThreadTs  String?        @map("slack_thread_ts")
  slackUserId    String?        @map("slack_user_id")
  userMessage    String         @map("user_message")
  status         String         @default("in_progress") // in_progress, completed, error
  durationMs     Int?           @map("duration_ms")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  requests       AgentRequest[]
  outcome        AgentOutcome?

  @@index([slackChannel])
  @@index([slackUserId])
  @@index([createdAt])
  @@map("agent_sessions")
}

model AgentRequest {
  id          String          @id @default(uuid())
  sessionId   String          @map("session_id")
  model       String
  promptKey   String?         @map("prompt_key")
  temperature Float?
  maxTokens   Int?            @map("max_tokens")
  createdAt   DateTime        @default(now()) @map("created_at")

  session     AgentSession    @relation(fields: [sessionId], references: [id])
  toolCalls   AgentToolCall[]

  @@index([sessionId])
  @@map("agent_requests")
}

model AgentToolCall {
  id         String       @id @default(uuid())
  requestId  String       @map("request_id")
  toolName   String       @map("tool_name")
  toolInput  Json?        @map("tool_input")
  toolOutput Json?        @map("tool_output")
  durationMs Int?         @map("duration_ms")
  success    Boolean      @default(true)
  error      String?
  createdAt  DateTime     @default(now()) @map("created_at")

  request    AgentRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@index([toolName])
  @@map("agent_tool_calls")
}

model AgentOutcome {
  id        String       @id @default(uuid())
  sessionId String       @unique @map("session_id")
  success   Boolean      @default(true)
  answer    String?
  error     String?
  toolsUsed String[]     @map("tools_used")
  createdAt DateTime     @default(now()) @map("created_at")

  session   AgentSession @relation(fields: [sessionId], references: [id])

  @@map("agent_outcomes")
}

// --- Token Tracking + Cost Visibility (Phase 2) ---

model AiTokenUsage {
  id               String   @id @default(uuid())
  sessionId        String?  @map("session_id")
  requestId        String?  @map("request_id")
  model            String
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  totalTokens      Int      @map("total_tokens")
  costUsd          Float    @map("cost_usd")
  source           String   // slack, cron
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@index([source])
  @@map("ai_token_usage")
}
